# Copiá este archivo como .env y completá con tus valores reales
# El archivo .env NUNCA se sube a GitHub

# Binance - por ahora solo lectura pública, estas keys son para el futuro (trading)
BINANCE_API_KEY=tu_api_key_aqui
BINANCE_SECRET=tu_secret_aqui

# Telegram - para recibir alertas (se configura en la segunda etapa)
TELEGRAM_BOT_TOKEN=tu_token_aqui
TELEGRAM_CHAT_ID=tu_chat_id_aqui

# Claude API — análisis fundamental (requerido para interpretar noticias con LLM)
ANTHROPIC_API_KEY=tu_key_aqui

# CryptoPanic — opcional, aumenta el rate limit (registro gratuito en cryptopanic.com)
# CRYPTOPANIC_TOKEN=tu_token_aqui
